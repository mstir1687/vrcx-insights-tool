{
  "name": "vrcx-insights-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "electron src/electron/main.js",
    "dev": "electron --inspect=5858 src/electron/main.js",
    "build:win": "electron-builder --win nsis portable --x64",
    "release:win": "electron-builder --win nsis portable --x64 --publish never",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "element-plus": "^2.13.7",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.0.12",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.mengluo.vrcx-insights-tool",
    "productName": "VRCX Insights Tool",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json",
      "Version"
    ],
    "extraMetadata": {
      "main": "src/electron/main.js"
    },
    "asar": true,
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${name}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    }
  }
}
